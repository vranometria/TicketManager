<UserControl x:Class="TicketManager.Components.TicketItemComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TicketManager.Components"
             mc:Ignorable="d" 
             d:Background="White" d:DesignWidth="800" Height="29">
    <Grid>
        <Label Content="{Binding Id}" d:Content="1000" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="Blue" MouseDoubleClick="TicketId_MouseDoubleClick" />
        <Label Content="{Binding Title}" d:Content="Sample Title" HorizontalAlignment="Left" Margin="65,0,0,0" VerticalAlignment="Top" Width="437"/>
    </Grid>
</UserControl>
