<UserControl x:Class="TicketManager.Components.TicketTreeComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TicketManager.Components"
             xmlns:components="clr-namespace:TicketManager.Components"
             xmlns:viewModels="clr-namespace:TicketManager.ViewModels"
             mc:Ignorable="d" Height="281" Width="424">
    <Grid>
        <TreeView Margin="10,10,10,10" ItemsSource="{Binding Tickets}">
            <TreeView.Resources>
                <HierarchicalDataTemplate ItemsSource="{Binding Items}" DataType="{x:Type viewModels:TicketItemViewModel}">
                    <components:TicketItemComponent />
                </HierarchicalDataTemplate>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>
