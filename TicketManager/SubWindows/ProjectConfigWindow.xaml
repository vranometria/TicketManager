<Window x:Class="TicketManager.SubWindows.ProjectConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketManager.SubWindows"
        mc:Ignorable="d"
        Title="設定" Height="494" Width="432">
    <Grid Margin="0,0,0,-6">
        <Label Content="Label" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TabControl Margin="10,41,10,90">
            <TabItem Header="プレイヤー">
                <Grid>
                    <ListBox Margin="10,10,91,74" d:ItemsSource="{d:SampleData ItemCount=5}" ItemsSource="{Binding Players}" SelectedItem="{Binding EdittingdPlayer, Mode=TwoWay}" DisplayMemberPath="Name"/>
                    <Grid HorizontalAlignment="Left" Margin="10,0,0,10" Width="324" Height="64" VerticalAlignment="Bottom">
                        <Label Content="表示名" HorizontalAlignment="Left" Margin="10,2,0,0" VerticalAlignment="Top"/>
                        <TextBox Text="{Binding EdittingdPlayer.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Height="28" Margin="10,26,0,0" TextWrapping="Wrap" d:Text="山田太郎" VerticalAlignment="Top" Width="132"/>
                        <Label Content="よみ" HorizontalAlignment="Left" Margin="149,2,0,0" VerticalAlignment="Top"/>
                        <TextBox Text="{Binding EdittingdPlayer.Yomi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Height="28" Margin="149,26,0,0" TextWrapping="Wrap" d:Text="やまだたろう" VerticalAlignment="Top" Width="124"/>
                        <Button Content="+" Height="28" Margin="286,26,10,0" VerticalAlignment="Top" Background="White" Click="RegisterPlayerButton_Clicked"/>
                    </Grid>
                    <Grid HorizontalAlignment="Left" Height="266" Margin="320,10,0,0" VerticalAlignment="Top" Width="39">
                        <Button Content="×" Click="PlayerDeleteButton_Clicked" Margin="0,10,0,0" VerticalAlignment="Top" Height="37"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="設定">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
        </TabControl>
        <Grid Margin="10,0,10,15" Height="70" VerticalAlignment="Bottom">
            <Button Content="Close" Background="white" Height="50" Margin="314,0,10,0" VerticalAlignment="Center" Click="CloseButton_Clicked"/>
        </Grid>
    </Grid>
</Window>
