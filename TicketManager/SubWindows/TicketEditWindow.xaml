<Window x:Class="TicketManager.SubWindows.TicketEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketManager.SubWindows"
        mc:Ignorable="d"
        xmlns:components="clr-namespace:TicketManager.Components"
        Height="Auto"
        Title="{Binding WindowTitle}" Width="800" Loaded="Window_Loaded">
    <Grid>
        <StackPanel Background="DarkGray">
            <StackPanel Orientation="Horizontal">
                <Label Content="{Binding TicketId}" d:Content="#1000" HorizontalAlignment="Left" Height="31" VerticalAlignment="Top" Width="52"/>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <Label Content="タイトル" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <TextBox Height="28" Width="500" TextWrapping="Wrap" Text="{Binding TicketInfo.Title, Mode=TwoWay}" d:Text="チケットのタイトル" VerticalAlignment="Top"/>
                </StackPanel>
            </StackPanel>
            <Grid Height="31" VerticalAlignment="Top">
                <Label Content="親チケット" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <TextBox Height="28" TextWrapping="Wrap" Text="{Binding ParentTicketId, Mode=TwoWay}" d:Text="0" VerticalAlignment="Top" Margin="61,0,655,0"/>
            </Grid>
            <Grid Height="138" VerticalAlignment="Top">
                <Label Content="概要" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.561,0.301"/>
                <TextBox TextWrapping="Wrap" Text="{Binding TicketInfo.Abstract, Mode=TwoWay}" d:Text="チケットの概要" Margin="10,41,10,10"/>
            </Grid>
            <WrapPanel Orientation="Horizontal" Height="56" >
                <StackPanel Orientation="Horizontal">
                    <Label Content="種別" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <ComboBox HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" ItemsSource="{Binding TicketTypeList}" SelectedItem="{Binding TicketType, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="ステータス" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <ComboBox HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" ItemsSource="{Binding TicketStatusList}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedTicketStatus, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="担当者" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <ComboBox HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" ItemsSource="{Binding PlayerList}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedPlayer, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="マイルストーン" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <ComboBox HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" ItemsSource="{Binding MilestoneList}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedMilestone, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <Label Content="開始日" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <DatePicker VerticalAlignment="Top" SelectedDate="{Binding TicketInfo.StartDate, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="期限日" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <DatePicker VerticalAlignment="Top" SelectedDate="{Binding TicketInfo.LimitDate, Mode=TwoWay}"/>
                </StackPanel>
            </WrapPanel>
            <StackPanel x:Name="ChildTicketsGrid" Height="Auto">
                <Button x:Name="NewChildTicketButton" Content="子チケット" Width="100" Background="White" Margin="0,0,700,75" Click="NewChildTicketButton_Click"/>
                <StackPanel Orientation="Vertical" Height="Auto">
                    <ItemsControl ItemsSource="{Binding ChildTickets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <components:TicketItemComponent/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
            <Grid Margin="5,0,15,10" Height="80" VerticalAlignment="Bottom">
                <Button Content="作成" Click="OKButton_Clicked" HorizontalAlignment="Left" Height="60" Margin="661,10,0,0" VerticalAlignment="Top" Width="109"/>
            </Grid>
        </StackPanel>

    </Grid>
</Window>
